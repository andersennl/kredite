{
  "name": "kredite",
  "version": "1.0.0",
  "description": "Self-hosted loan portfolio tracker with amortization schedules and payoff priorities",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andersennl/kredite.git"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "chart.js": "^4.4.8",
    "express": "^4.21.2",
    "sirv": "^3.0.1",
    "svelte": "^5.23.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "concurrently": "^9.1.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.8"
  }
}
